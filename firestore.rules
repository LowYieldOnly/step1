rules_version = '2';
// Access control: ECU students (@students.ecu.edu) + an admin allowlist.
// Deploy with:  firebase deploy --only firestore:rules
// (or paste into Firebase console → Firestore → Rules). Keep the allowlist in
// sync with ACCESS_EMAILS / ACCESS_DOMAINS in index.html.
service cloud.firestore {
  match /databases/{database}/documents {
    function allowedEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.matches('.*@students[.]ecu[.]edu$')
          || request.auth.token.email in ['dylanwlewis@protonmail.com']
        );
    }
    // Each user can read/write only their own profile document, and only if
    // their email is on the allowlist.
    match /users/{uid} {
      allow read, write: if allowedEmail() && request.auth.uid == uid;
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
