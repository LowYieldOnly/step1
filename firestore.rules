rules_version = '2';
// Access control: any ECU email (@ecu.edu or any subdomain) + an admin allowlist.
// Deploy with:  firebase deploy --only firestore:rules
// (or paste into Firebase console → Firestore → Rules). Keep the allowlist in
// sync with ACCESS_EMAILS / ACCESS_DOMAINS in index.html.
service cloud.firestore {
  match /databases/{database}/documents {
    function allowedEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          request.auth.token.email.matches('.*@([a-z0-9-]+[.])*ecu[.]edu')
          || request.auth.token.email in ['dylanwlewis@protonmail.com', 'trial@lowyieldonly.com']
        );
    }
    // Each user can read/write only their own profile document AND everything
    // under it (e.g. the backups/ version-history subcollection), and only if
    // their email is on the allowlist. The /{document=**} makes it recursive.
    match /users/{uid}/{document=**} {
      allow read, write: if allowedEmail() && request.auth.uid == uid;
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
